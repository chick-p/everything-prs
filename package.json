{
  "name": "everything-prs",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "lint": "run-p lint:*",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint \"./src/**/*.ts\"",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier -w .",
    "fix:eslint": "pnpm run lint:eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@eslint/js": "^10.0.1",
    "@octokit/types": "^16.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.106.0"
  }
}
